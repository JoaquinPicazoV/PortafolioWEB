# Fuerza que npm audite automáticamente las dependencias al instalar
audit=true

# Detiene la instalación si se encuentra una vulnerabilidad (para obligar a solucionarla)
# Descomentar la siguiente línea si quieres que las instalaciones fallen con vulnerabilidades
# audit-level=high

# Desactiva mensajes de financiación para evitar fatiga de alertas
fund=false

# Opcional: Para evitar conflictos en un proyecto maduro (dependiendo del ecosistema local)
legacy-peer-deps=true
